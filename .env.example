# Kafka — host network
KAFKA_BOOTSTRAP_SERVERS=127.0.0.1:9092
KAFKA_TOPIC=order_events
KAFKA_DLQ_TOPIC=order_events_dlq

# ClickHouse — host network
CLICKHOUSE_HOST=127.0.0.1
CLICKHOUSE_PORT=8123
CLICKHOUSE_DATABASE=orders
CLICKHOUSE_TABLE=events_raw

# Producer
PRODUCER_RATE=500
PRODUCER_TOTAL_EVENTS=100000
PRODUCER_METRICS_PORT=8010

# Consumer
CONSUMER_GROUP=clickhouse-sink
CONSUMER_ID=consumer-1
CONSUMER_BATCH_SIZE=1000
CONSUMER_AUTO_COMMIT=false
METRICS_PORT=8000

# Kafka tuning (production-like)
SESSION_TIMEOUT_MS=45000
MAX_POLL_INTERVAL_MS=300000
MAX_POLL_RECORDS=500

# Lab: simulate slow ClickHouse insert (0 = normal)
SIMULATE_SLOW_MS=0

# Insert reliability
INSERT_MAX_RETRIES=3
INSERT_RETRY_BASE_MS=500
